# AfriLang – environment variables
# Copy to .env and fill in your values.
# The server runs in stub/demo mode when provider keys are empty.

# ── Provider credentials ────────────────────────────────────────────────────────
# Hugging Face token – https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# Sunbird AI token – register at https://api.sunbird.ai/register
SUNBIRD_API_KEY=

# ── AfriLang internal auth ──────────────────────────────────────────────────────
# Secret for signing API keys. Generate with: openssl rand -hex 32
AFRILANG_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# How long issued keys stay valid in seconds (default = 1 year)
API_KEY_TTL_SECONDS=31536000

# ── Rate limiting ───────────────────────────────────────────────────────────────
# Requests per minute for /translate
RATE_LIMIT_RPM=60
# Requests per minute for /translate/batch
RATE_LIMIT_BATCH_RPM=10

# ── Redis (optional – for production rate limiting) ─────────────────────────────
# Leave empty to use in-memory rate limiting (not shared across workers)
REDIS_URL=

# ── Provider base URLs (override for self-hosted models) ───────────────────────
SUNBIRD_BASE_URL=https://api.sunbird.ai
HUGGINGFACE_BASE_URL=https://api-inference.huggingface.co/models

# ── Fallback model (covers 200 languages) ──────────────────────────────────────
DEFAULT_MODEL_ID=facebook/nllb-200-distilled-600M

# ── Misc ───────────────────────────────────────────────────────────────────────
BASE_URL=http://localhost:8000
DEBUG=false

# HTTP timeouts in seconds
HTTP_TIMEOUT=30
HTTP_TIMEOUT_STT=60
