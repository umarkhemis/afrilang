# AfriLang – environment variables
# Copy this file to .env and fill in your real keys.
# The app runs in stub/demo mode when keys are left empty.

# Hugging Face Inference API token
# Get yours at https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# Sunbird Sunflower API key
# TODO: obtain from Sunbird AI partnership (https://sunbird.ai)
SUNBIRD_API_KEY=

# Base URL for the AfriLang API (used in SDK / docs)
BASE_URL=http://localhost:8000

# Default fallback model (NLLB-200 covers 200 languages)
DEFAULT_MODEL_ID=facebook/nllb-200-distilled-600M
